{
  "name": "app-ai",
  "version": "1.0.0",
  "description": "App AI service for LimeSpot - Claude API integration for Cloudflare Workers",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "test": "vitest",
    "verify:caching": "node scripts/verify-caching.mjs",
    "lint": "eslint 'src/**/*.js' 'test/**/*.js'",
    "lint:fix": "eslint --fix 'src/**/*.js' 'test/**/*.js'",
    "format": "prettier --write '{src,test}/**/*.js' '*.js' '*.cjs' '*.json' '*.md'",
    "format-check": "prettier --check '{src,test}/**/*.js' '*.js' '*.cjs' '*.json' '*.md'",
    "update-deps": "npm update && npm audit fix"
  },
  "keywords": [
    "proxy",
    "claude",
    "anthropic",
    "ai",
    "cloudflare",
    "workers"
  ],
  "author": "LimeSpot",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^15.15.0",
    "prettier": "^3.8.4",
    "vitest": "^2.1.9",
    "wrangler": "^3.114.15"
  }
}
